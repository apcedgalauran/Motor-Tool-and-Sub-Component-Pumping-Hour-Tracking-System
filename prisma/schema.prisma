generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL moved to `prisma.config.ts` for Prisma v7+.
}

model Motor {
  id              String        @id @default(cuid())
  name            String
  serialNumber    String        @unique
  location        String?
  dateOut         DateTime?
  dateIn          DateTime?
  status          String        @default("ON_LOCATION")
  customStatusId  String?
  pumpingHours    Float         @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customStatus CustomStatus? @relation(fields: [customStatusId], references: [id])
  assemblies            Assembly[]
  hourLogs              HourLog[]
  editLogs              MotorEditLog[]
  subComponentHourLogs  SubComponentHourLog[]
}

model CustomStatus {
  id          String   @id @default(cuid())
  label       String   @unique
  color       String
  isPermanent Boolean  @default(true)
  createdAt   DateTime @default(now())

  motors Motor[]
}

model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  passwordHash  String
  createdAt     DateTime   @default(now())
  hourLogs              HourLog[]
  motorEditLogs         MotorEditLog[]
  subComponentHourLogs  SubComponentHourLog[]
}

model SubComponent {
  id              String           @id @default(cuid())
  type            String
  serialNumber    String           @unique
  cumulativeHours Float            @default(0)
  status          String           @default("AVAILABLE")
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  assemblies            Assembly[]
  subComponentHourLogs  SubComponentHourLog[]
}

model Assembly {
  id              String    @id @default(cuid())
  motorId         String
  subComponentId  String
  dateAssembled   DateTime  @default(now())
  dateRemoved     DateTime?
  hoursAtAssembly Float
  hoursAtRemoval  Float?
  hoursAccrued    Float?

  motor        Motor        @relation(fields: [motorId], references: [id])
  subComponent SubComponent @relation(fields: [subComponentId], references: [id])

  @@index([motorId, dateRemoved])
}

model HourLog {
  id         String   @id @default(cuid())
  motorId    String
  hoursAdded Float
  totalAfter Float
  userId     String?
  rigName    String?
  wellNumber String?
  notes      String?
  createdAt  DateTime @default(now())

  motor Motor @relation(fields: [motorId], references: [id])
  user  User? @relation(fields: [userId], references: [id])
}

model MotorEditLog {
  id            String   @id @default(cuid())
  motorId       String
  userId        String
  editedAt      DateTime @default(now())
  changedFields Json

  motor Motor @relation(fields: [motorId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([motorId, editedAt])
  @@index([userId, editedAt])
}

model SubComponentHourLog {
  id             String   @id @default(cuid())
  subComponentId String
  motorId        String?
  userId         String
  hoursAdded     Float
  totalAfter     Float
  rigName        String
  wellNumber     String
  notes          String?
  createdAt      DateTime @default(now())

  subComponent SubComponent @relation(fields: [subComponentId], references: [id], onDelete: Cascade)
  motor        Motor?       @relation(fields: [motorId], references: [id], onDelete: SetNull)
  user         User         @relation(fields: [userId], references: [id])

  @@index([subComponentId, createdAt])
  @@index([motorId, createdAt])
  @@index([userId, createdAt])
}
